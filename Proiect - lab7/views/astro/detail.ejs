<!DOCTYPE html>
<html>
<head>
  <link rel="stylesheet" href="/style.css">
  <title><%= session.tip %></title>
</head>
<body class="<%= theme === 'dark' ? 'dark' : '' %>">
  <h1><%= session.tip %></h1>
  <p><%= session.descriere %></p>

  <h2>Detalii</h2>
  <p>⏱ Durată: <%= session.durata %></p>
  <p>💰 Preț: <%= session.pret %></p>

  <h2>Ce include</h2>
  <ul>
    <% session.include.forEach(item => { %>
      <li>✦ <%= item %></li>
    <% }) %>
  </ul>

  <br>
  <a class="btn" href="/astro">Înapoi la dashboard</a>
  <a class="btn" href="/logout">Logout</a>

</body>
</html> 