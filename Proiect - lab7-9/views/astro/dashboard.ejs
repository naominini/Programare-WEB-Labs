<!DOCTYPE html>
<html>
<head>
  <link rel="stylesheet" href="/style.css">
  <title>Dashboard</title>
</head>
<body class="<%= theme === 'dark' ? 'dark' : '' %>">
  <% if (theme === 'dark') { %>
    <p><a class="theme-btn" href="/astro/theme/light">☀️ Schimbă la light</a></p>
  <% } else { %>
    <p><a class="theme-btn" href="/astro/theme/dark">🌙 Schimbă la dark</a></p>
  <% } %>
  
  <h1>✦ Online Astrology Consultation ✦</h1>
  <p><i>Discover yourself through the wisdom of the stars</i></p>

  <br>

  <p>Bună, <strong><%= user.nume %></strong>! ✦</p>
  <p>Vizite în sesiunea curentă: <%= views %></p>

  <br>

  <p>
    Whether you are at a crossroads in life, curious about your deeper personality,
    or simply drawn to explore what the cosmos has to say about your journey,
    this platform offers a safe, thoughtful and professional space to do exactly that.
  </p>

  <br>

  <h2>Consultații disponibile</h2>
  <ul>
    <% sessions.forEach(s => { %>
      <li style="display:flex; align-items:center; justify-content:center; gap:8px">
        <a href="/astro/<%= s._id %>"><%= s.tip %></a>
        — <%= s.durata %> — <%= s.pret %> RON
        <a class="btn" href="/astro/<%= s._id %>/book">📅 Programează</a>
        <% if (user.role === 'admin') { %>
          <a class="btn" href="/astro/<%= s._id %>/edit">✏️ Editează</a>
          <form action="/astro/<%= s._id %>/delete" method="POST">
            <button type="submit" onclick="return confirm('Sigur vrei să ștergi?')">🗑️ Șterge</button>
          </form>
        <% } %>
      </li>
    <% }) %>
  </ul>

  <br>
  <% if (user.role === 'admin') { %>
    <a class="btn" href="/astro/add">➕ Adaugă consultație</a>
  <% } %>

  <br>
  <a class="btn" href="/astro/mine">📋 Programările mele</a>

  <br>

  <a class="btn" href="/logout">Logout</a>

</body>
</html>